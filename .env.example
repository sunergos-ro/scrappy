# Server
SCRAPPY_ADDR=:3000
SCRAPPY_ALLOWED_IPS=127.0.0.1,::1
SCRAPPY_TRUSTED_PROXY_CIDRS=

# Request security
SCRAPPY_ALLOWED_TARGET_HOSTS=
SCRAPPY_BLOCK_PRIVATE_NETWORKS=true
SCRAPPY_ALLOW_LOOPBACK_TARGETS=false
SCRAPPY_ADMIN_TOKEN=
SCRAPPY_MAX_REQUEST_BODY_BYTES=1048576
SCRAPPY_MAX_WAIT_MS=20000
SCRAPPY_MAX_TIMEOUT_MS=60000
SCRAPPY_MAX_VIEWPORT_WIDTH=2560
SCRAPPY_MAX_VIEWPORT_HEIGHT=2560
SCRAPPY_MAX_DEVICE_SCALE_FACTOR=3

# Browser pool
BROWSER_POOL_ENABLED=true
BROWSER_POOL_MIN_SIZE=2
BROWSER_POOL_MAX_SIZE=4
BROWSER_POOL_LEASE_TIMEOUT=5
BROWSER_POOL_IDLE_TTL=120
BROWSER_POOL_MAX_REUSE=20
BROWSER_POOL_SPAWN_TIMEOUT=30
BROWSER_POOL_HANG_TIMEOUT=120
BROWSER_POOL_SUPERVISOR_INTERVAL=10
BROWSER_POOL_ALLOW_STANDALONE_FALLBACK=false

# Render defaults
SCRAPPY_DEFAULT_VIEWPORT_WIDTH=1440
SCRAPPY_DEFAULT_VIEWPORT_HEIGHT=756
SCRAPPY_DEFAULT_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36
SCRAPPY_DEFAULT_WAIT_MS=2000
SCRAPPY_DEFAULT_TIMEOUT_MS=30000
SCRAPPY_DEFAULT_FORMAT=jpeg
SCRAPPY_DEFAULT_QUALITY=90
SCRAPPY_DEFAULT_DEVICE_SCALE_FACTOR=1

# Browser binary (optional)
SCRAPPY_CHROME_BIN=
SCRAPPY_CHROME_NO_SANDBOX=false

# R2 (required only for /screenshot)
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=
R2_REGION=auto

# Observability (optional)
SENTRY_DSN=
