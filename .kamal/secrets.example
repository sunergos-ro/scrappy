# Secrets defined here are available to config/deploy.yml under:
# - registry/password
# - env/secret
# - builder/secrets
#
# This file should not contain raw credentials in git.
# Copy to `.kamal/secrets` and fill via password manager or environment.

# Example: pull values from 1Password
# SECRETS=$(kamal secrets fetch --adapter 1password --account your-account.1password.com --from Vault/Item SCRAPPY_ADMIN_TOKEN R2_ACCESS_KEY_ID R2_SECRET_ACCESS_KEY SENTRY_DSN KAMAL_REGISTRY_PASSWORD)
# SCRAPPY_ADMIN_TOKEN=$(kamal secrets extract SCRAPPY_ADMIN_TOKEN ${SECRETS})
# R2_ACCESS_KEY_ID=$(kamal secrets extract R2_ACCESS_KEY_ID ${SECRETS})
# R2_SECRET_ACCESS_KEY=$(kamal secrets extract R2_SECRET_ACCESS_KEY ${SECRETS})
# SENTRY_DSN=$(kamal secrets extract SENTRY_DSN ${SECRETS})
# KAMAL_REGISTRY_PASSWORD=$(kamal secrets extract KAMAL_REGISTRY_PASSWORD ${SECRETS})

# Example: forward from local shell environment
# SCRAPPY_ADMIN_TOKEN=${SCRAPPY_ADMIN_TOKEN}
# R2_ACCESS_KEY_ID=${R2_ACCESS_KEY_ID}
# R2_SECRET_ACCESS_KEY=${R2_SECRET_ACCESS_KEY}
# SENTRY_DSN=${SENTRY_DSN}
# KAMAL_REGISTRY_PASSWORD=${KAMAL_REGISTRY_PASSWORD}
